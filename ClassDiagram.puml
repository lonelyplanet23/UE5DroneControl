        +SendArrayTask(pathMap, mode, OnComplete)
        +SendArrayTaskFromData(pathDataMap, mode, OnComplete)
        +GetCachedGpsAnchor(droneId, lat, lon, alt) : bool
        +GetHttpClient() : UDroneHttpClient*
        +GetWebSocketClient() : UDroneWebSocketClient*
        --
        -StartPolling()
        -StopPolling()
        -PollDroneList()
        -OnDroneListResponse(bSuccess, body)
        -OnRegisterDroneResponse(bSuccess, body)
