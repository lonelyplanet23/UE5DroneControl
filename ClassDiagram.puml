        +bIsMoving : bool
        +ControlledDrone : TWeakObjectPtr<AActor>
        .. Events ..
        +OnExecutionStateChanged : FOnDronePathExecutionStateChanged
        --
        .. Waypoint API ..
        +AddWaypoint(location, segmentSpeed) : int32
        +RemoveWaypoint(index) : bool
