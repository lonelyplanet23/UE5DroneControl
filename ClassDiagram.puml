        .. BP Implementable Events ..
        #OnDroneRegistered(droneId)
        #OnDroneUnregistered(droneId)
        #OnSettingsSaved()
        #OnGoToPreviewBlockedByNoConnection()
        --
        -HandleBackendRegisterResponse(bSuccess, responseBody)
        -GetMainMenuPC() : AMainMenuPlayerController*
        -PendingBackendRegisterDroneId : int32
        -PendingBackendRegisterIpAddress : FString
    }

    UMainMenuWidget --> UDroneNetworkManager : uses >
    UMainMenuWidget --> UDroneRegistrySubsystem : uses >
}

' ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
'  Cross-package relationships
' ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

' Network Manager → Registry
UDroneNetworkManager --> UDroneRegistrySubsystem : syncs drone list >

' Registry → Receiver Actor (by AActor* handle)
UDroneRegistrySubsystem "1" --> "0..*" ARealTimeDroneReceiver : tracks via ReceiverActors >

' Receiver ← Network events
ARealTimeDroneReceiver ..> UDroneNetworkManager : subscribes OnDroneWsEvent >

' Descriptor usage
UDroneRegistrySubsystem ..> FDroneDescriptor
ARealTimeDroneReceiver ..> FDroneDescriptor : applied via ApplyDescriptor >

' Telemetry flow
ARealTimeDroneReceiver ..> FDroneTelemetrySnapshot : produces >
UDroneRegistrySubsystem ..> FDroneTelemetrySnapshot : broadcasts >

' Command mode
ADroneOpsPlayerController ..> EDroneCommandMode : queries/sets >
UDroneRegistrySubsystem ..> EDroneCommandMode : stores per drone >

' ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
'  Legend
' ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
legend bottom right
  |  Symbol  |  Meaning  |
  | --|>  |  Inheritance (extends)  |
  | ..|>  |  Interface implementation  |
  |  *--  |  Composition (owns, lifetime bound)  |
  |  o--  |  Aggregation (references)  |
  |  -->  |  Directed association (uses, calls)  |
  |  ..>  |  Dependency (creates / subscribes)  |
  |  <<>>  |  UE4/UE5 macro stereotype  |
endlegend

