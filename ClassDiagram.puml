package "DroneOps::Registry" #E8F5E9 {

    class UDroneRegistrySubsystem <<UGameInstanceSubsystem>> {
        .. Events (Multicast Delegates) ..
        +OnDroneRegistered : FOnDroneRegistered
        +OnPrimarySelectionChanged : FOnPrimarySelectionChanged
        +OnTelemetryUpdated : FOnTelemetryUpdated
        +OnControlLockChanged : FOnControlLockChanged
        +OnDroneCommandModeChanged : FOnDroneCommandModeChanged
        --
        +Initialize(Collection)
        +Deinitialize()
        +SetCoordinateService(service)
        +GetCoordinateService() : ICoordinateService
        .. Drone Registration ..
        +RegisterDrone(descriptor : FDroneDescriptor)
        +UnregisterDrone(droneId)
        +MarkDroneAvailability(droneId, availability)
        +RegisterSenderPawn(droneId, pawn)
        +RegisterReceiverActor(droneId, actor)
        +SaveRegisteredDrones() : bool
        +LoadRegisteredDrones() : bool
        .. Telemetry ..
        +UpdateTelemetry(droneId, snapshot)
        +GetTelemetry(droneId, outSnapshot) : bool
        .. Selection ..
        +SetPrimarySelectedDrone(droneId)
        +GetPrimarySelectedDrone() : int32
        +SetMultiSelectedDrones(droneIds)
        +GetMultiSelectedDrones() : TArray<int32>
        +ClearSelection()
        .. Control Lock ..
        +ApplyControlLock(droneId, reason)
        +ReleaseControlLock(droneId)
        +IsControlLocked(droneId, outReason) : bool
        .. Command Mode ..
        +SetDroneCommandMode(droneId, mode)
        +CycleDroneCommandMode(droneId)
        +GetDroneCommandMode(droneId) : EDroneCommandMode
        .. Query ..
        +GetAllDroneDescriptors() : TArray<FDroneDescriptor>
        +GetDroneDescriptor(droneId, out) : bool
        +GetSenderPawn(droneId) : APawn*
        +GetReceiverActor(droneId) : AActor*
        +IsDroneRegistered(droneId) : bool
        +GetSelectedDroneMask() : int32
        +GetDroneBitIndex(droneId) : int32
        --
        -CoordinateService : ICoordinateService
        -DroneDescriptors : TMap<int32,FDroneDescriptor>
        -SenderPawns : TMap<int32,APawn*>
        -ReceiverActors : TMap<int32,AActor*>
        -TelemetryCache : TMap<int32,FDroneTelemetrySnapshot>
        -PrimarySelectedDroneId : int32
        -MultiSelectedDroneIds : TArray<int32>
        -ControlLocks : TMap<int32,EDroneControlLockReason>
        -CommandModes : TMap<int32,EDroneCommandMode>
    }

    UDroneRegistrySubsystem --> ICoordinateService : uses >
    UDroneRegistrySubsystem ..> FDroneDescriptor : stores >
    UDroneRegistrySubsystem ..> FDroneTelemetrySnapshot : caches >
}

