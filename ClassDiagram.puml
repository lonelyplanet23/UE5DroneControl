        +NedLocation : FVector
        +GeographicLocation : FVector
        +Velocity : FVector
        +Attitude : FRotator
        +Altitude : float
        +LastUpdateTime : double
    }

    class FDroneTargetCommand <<USTRUCT>> {
        +DroneId : int32
        +TargetWorldLocation : FVector
        +TargetNedLocation : FVector
        +TargetGeographicLocation : FVector
        +Mode : int32
        +IssuedAt : double
    }

    class FCameraModeState <<USTRUCT>> {
        +CameraMode : EDroneCameraMode
        +FollowDroneId : int32
        +LastFollowLocation : FVector
        +LastFollowRotation : FRotator
    }

    class FFormationStep <<USTRUCT>> {
        +StepId : int32
        +DurationSec : float
        +MemberTargets : TMap<int32,FVector>
    }

    class FFormationMemberSlot <<USTRUCT>> {
        +DroneId : int32
        +RoleName : FString
        +RelativeOffset : FVector
    }

    class FFormationExecutionState <<USTRUCT>> {
        +PresetId : int32
        +StepIndex : int32
        +ElapsedSec : float
        +bPaused : bool
        +ParticipantIds : TArray<int32>
    }

    FDroneTelemetrySnapshot --> EDroneAvailability
    FCameraModeState --> EDroneCameraMode
}

