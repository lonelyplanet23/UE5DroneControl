package "DroneOps::Core" #F9FBE7 {

    enum EDroneAvailability <<UENUM>> {
        Online
        Offline
        Lost
    }

    enum EDroneCommandMode <<UENUM>> {
        Move
        Scout
        Patrol
        Attack
        --
        +{static} DroneCommandModeToProtocolString(mode) : FString
        +{static} DroneCommandModeFromProtocolString(str) : EDroneCommandMode
    }

    enum EDroneControlLockReason <<UENUM>> {
        None
        FormationPlayback
        Offline
        InvalidTarget
    }

    enum EDroneCameraMode <<UENUM>> {
        Follow
        Free
        TopDown
    }

    class FDroneDescriptor <<USTRUCT>> {
        +Name : FString
        +DroneId : int32
        +Slot : int32
        +BackendIdString : FString
        +IpAddress : FString
        +ControlPort : int32
        +MavlinkSystemId : int32
        +BitIndex : int32
        +ThemeColor : FLinearColor
        +UEReceivePort : int32
        +TopicPrefix : FString
    }

    class FDroneTelemetrySnapshot <<USTRUCT>> {
        +DroneId : int32
        +Availability : EDroneAvailability
