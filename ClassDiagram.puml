        +SetClickTargetLocation(targetLoc, mode) override
        .. IDroneSelectableInterface ..
        +GetDroneId_Implementation() : int32
        +OnPrimarySelected_Implementation()
        +OnSecondarySelected_Implementation(bSelected)
        +OnHoveredChanged_Implementation(bHovered)
        +OnDeselected_Implementation()
        .. IDroneInfoProvider ..
        +GetDroneInfoSnapshot_Implementation() : FDroneTelemetrySnapshot
        +GetDroneDisplayName_Implementation() : FString
        +GetThemeColor_Implementation() : FLinearColor
        --
        -OnWebSocketTelemetry(inDroneId, snapshot)
        -OnDroneWsEvent(inDroneId, event, lat, lon, alt)
        -ParseYAMLData(yamlStr, outData) : bool
        -NEDToUE5(nedPos) : FVector
        -QuatToEuler(q) : FRotator
        -ProcessPacket(data)
        -PushTelemetry(droneData, worldPos, worldRot)
        -TargetLocation : FVector
        -TargetRotation : FRotator
        -bIsPaused : bool
    }

    AUE5DroneControlCharacter <|-- ARealTimeDroneReceiver
    ARealTimeDroneReceiver ..|> IDroneSelectableInterface
    ARealTimeDroneReceiver ..|> IDroneInfoProvider
    ARealTimeDroneReceiver ..> FDroneYAMLData : parses >
}

